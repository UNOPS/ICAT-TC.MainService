# Copy this file to .env and fill in your values:
#   cp .env.example .env

PORT= # Application Port

# Database — use DATABASE_HOST for local MySQL, or SOCKET_PATH for cloud SQL sockets
DATABASE_HOST=
# SOCKET_PATH=
DATABASE_PORT=
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_NAME=

# Service URLs
MAIN_URL=
MAIN_SERVER_URL=
AUTH_URL=
AUDIT_URL=
ClientURl=

# JWT (JWT_VERIFICATION_TOKEN_SECRET must match Auth Service)
JWT_VERIFICATION_TOKEN_SECRET=
JWT_expiresIn=
KEY=

# Mail
EMAIL=
EMAIL_PASSWORD=
EMAIL_HOST=

# Temporary file storage path for report generation
TEMP_FILE_SAVE_URL=

# Google Cloud Storage
PROJECT_ID=
PRIVATE_KEY=
CLIENT_EMAIL=
STORAGE_MEDIA_BUCKET=
